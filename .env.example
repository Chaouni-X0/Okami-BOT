# Server Configuration
PORT=8080
NODE_ENV=production
PYTHON_PATH=python3

# Facebook Configuration
# Get these from https://developers.facebook.com/
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FB_PAGE_ID=your_facebook_page_id_here
VERIFY_TOKEN=your_webhook_verify_token_here

# Admin Configuration
# Set a strong password for developer mode access
ADMIN_PASSWORD=your_secure_admin_password_here

# Database Configuration (Optional)
# For MongoDB support
MONGODB_URI=mongodb://localhost:27017/okami

# Data Directory
DATA_DIR=./data

# Logging
LOG_LEVEL=info

# Environment
DEBUG=false
