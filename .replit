# ═══════════════════════════════════════════════════════════════
# ملف إعدادات Replit لبوت أوكامي 🐺
# ═══════════════════════════════════════════════════════════════

# الأمر الرئيسي لتشغيل البوت
run = "python3 main.py"

# اللغة المستخدمة
language = "python3"

# إعدادات الحزم
[packager]
language = "python3"

[packager.features]
packageSearch = true
guessImports = true

# إعدادات Nix (بيئة النظام)
[nix]
channel = "stable-23_11"

# إعدادات اللغة
[languages]

[languages.python3]
pattern = "**/*.py"

[languages.python3.languageServer]
start = "pylsp"

# إعدادات النشر (Deployment)
[deployment]
run = ["sh", "-c", "python3 main.py"]

# إعدادات البيئة
[env]
PYTHONPATH = "${REPL_HOME}"
