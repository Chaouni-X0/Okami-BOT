{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600
  },
  "variables": {
    "PORT": "8080",
    "NODE_ENV": "production",
    "PYTHON_PATH": "python3",
    "DATA_DIR": "./data"
  }
}
